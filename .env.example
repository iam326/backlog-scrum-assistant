# Backlog設定
# スペースURL（例: https://your-space.backlog.com or https://your-space.backlog.jp）
BACKLOG_SPACE_URL=https://your-space.backlog.com
# APIキー（Backlog > 個人設定 > API > 新しいAPIキーを発行）
BACKLOG_API_KEY=your_api_key_here
# 対象プロジェクトキー（Backlogのプロジェクト設定から確認）
BACKLOG_PROJECT_KEY=YOUR_PROJECT

# チームフィルタ（任意）
# 担当者名がこのプレフィックスで始まるメンバーのみ表示
# 未設定の場合は全メンバーを表示
TEAM_PREFIX=

# スプリント開始曜日（任意）
# 0=月, 1=火, 2=水, 3=木, 4=金, 5=土, 6=日（デフォルト: 0）
SPRINT_START_DOW=0
